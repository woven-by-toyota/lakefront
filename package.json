{
  "name": "@woven-planet/lakefront",
  "description": "React UI Components",
  "version": "9.1.2",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "homepage": "https://github.com/woven-by-toyota/lakefront",
  "license": "Apache-2.0",
